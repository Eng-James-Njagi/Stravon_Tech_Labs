    <script>
        function showTab(tabName) {
            // Hide all tab contents
            const tabContents = document.querySelectorAll('.sp-tab-content');
            tabContents.forEach(tab => {
                tab.classList.remove('sp-active');
            });

            // Remove active class from all buttons
            const tabButtons = document.querySelectorAll('.sp-tab-btn');
            tabButtons.forEach(btn => {
                btn.classList.remove('sp-active');
            });

            // Show selected tab content
            document.getElementById(tabName).classList.add('sp-active');
            
            // Add active class to clicked button
            event.target.classList.add('sp-active');
        }

        // Add smooth scrolling and entrance animations
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.sp-package-card');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.animation = 'sp-fadeInUp 0.6s ease-out forwards';
                    }
                });
            }, {
                threshold: 0.1
            });

            cards.forEach(card => {
                observer.observe(card);
            });
        });
    </script>
