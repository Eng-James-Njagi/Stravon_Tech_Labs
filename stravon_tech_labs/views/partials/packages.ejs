    <script>
        // Tab functionality
        document.querySelectorAll('.sp-tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const tabId = btn.dataset.tab;
                
                // Remove active class from all tabs and contents
                document.querySelectorAll('.sp-tab-btn').forEach(b => b.classList.remove('sp-active'));
                document.querySelectorAll('.sp-tab-content').forEach(c => c.classList.remove('sp-active'));
                
                // Add active class to clicked tab and corresponding content
                btn.classList.add('sp-active');
                document.getElementById(tabId).classList.add('sp-active');
                
                // Reset all toggles in the new tab
                const newTabContent = document.getElementById(tabId);
                newTabContent.querySelectorAll('.sp-toggle-btn').forEach(toggleBtn => {
                    toggleBtn.classList.remove('sp-active');
                    toggleBtn.querySelector('.sp-toggle-icon').textContent = '▶';
                });
                newTabContent.querySelectorAll('.sp-toggle-content').forEach(content => {
                    content.classList.remove('sp-active');
                });
                
                // Activate first toggle in new tab
                const firstToggle = newTabContent.querySelector('.sp-toggle-btn');
                const firstContent = newTabContent.querySelector('.sp-toggle-content');
                if (firstToggle && firstContent) {
                    firstToggle.classList.add('sp-active');
                    firstToggle.querySelector('.sp-toggle-icon').textContent = '▼';
                    firstContent.classList.add('sp-active');
                }
                
                // Animate cards
                animateCards();
            });
        });

        // Toggle functionality
        document.querySelectorAll('.sp-toggle-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const toggleId = btn.dataset.toggle;
                const content = document.getElementById(toggleId);
                const icon = btn.querySelector('.sp-toggle-icon');
                
                // Toggle active state
                btn.classList.toggle('sp-active');
                content.classList.toggle('sp-active');
                
                // Update icon
                if (btn.classList.contains('sp-active')) {
                    icon.textContent = '▼';
                } else {
                    icon.textContent = '▶';
                }
                
                // Animate cards when content is shown
                if (content.classList.contains('sp-active')) {
                    setTimeout(() => {
                        animateCards();
                    }, 100);
                }
            });
        });

        // Animate cards function
        function animateCards() {
            const cards = document.querySelectorAll('.sp-toggle-content.sp-active .sp-package-card');
            cards.forEach((card, index) => {
                card.classList.add('sp-loading');
                setTimeout(() => {
                    card.classList.remove('sp-loading');
                    card.classList.add('sp-loaded');
                }, index * 100);
            });
        }

        // Initial animation
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                animateCards();
            }, 500);
        });

        // Package button click handlers
        document.querySelectorAll('.sp-package-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                // Add click animation
                btn.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    btn.style.transform = '';
                }, 150);
                
                // You can add your actual functionality here
                console.log('Package selected:', btn.closest('.sp-package-card').querySelector('.sp-package-title').textContent);
            });
        });
        document.querySelectorAll('.sp-package-btn[data-link]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Add click animation
                btn.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    btn.style.transform = '';
                }, 150);
                
                // Get the link from data attribute
                const link = btn.dataset.link;
                
                // Open WhatsApp
                window.open(link, '_blank');
            });
        });
    </script>
