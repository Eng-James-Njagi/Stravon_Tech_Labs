<div class="stravon-faq-contact-wrapper">
    <div class="stravon-bg-pattern"></div>
    
    <div class="stravon-container">
        <!-- FAQ Section -->
        <section class="stravon-faq-section">
            <div class="stravon-section-header stravon-slide-in">
                <h2 class="stravon-section-title">Frequently Asked Questions</h2>
                <p class="stravon-section-subtitle">Get answers to common questions about our services</p>
            </div>
            
            <div class="stravon-faq-container">
                <div class="stravon-faq-item stravon-slide-in">
                    <div class="stravon-faq-question">
                        <span>How long does a typical website project take?</span>
                        <div class="stravon-faq-toggle"></div>
                    </div>
                    <div class="stravon-faq-answer">
                        <div class="stravon-faq-answer-content">
                            Project timelines vary based on complexity. Landing pages take 3-5 days, while e-commerce sites can take 30-60 days. We'll provide a detailed timeline with your proposal.
                        </div>
                    </div>
                </div>

                <div class="stravon-faq-item stravon-slide-in">
                    <div class="stravon-faq-question">
                        <span>Do you provide website maintenance after launch?</span>
                        <div class="stravon-faq-toggle"></div>
                    </div>
                    <div class="stravon-faq-answer">
                        <div class="stravon-faq-answer-content">
                            Yes, we offer comprehensive maintenance plans starting from KES 4,000/month, including security updates, backups, and content updates.
                        </div>
                    </div>
                </div>

                <div class="stravon-faq-item stravon-slide-in">
                    <div class="stravon-faq-question">
                        <span>Can you integrate M-Pesa payments?</span>
                        <div class="stravon-faq-toggle"></div>
                    </div>
                    <div class="stravon-faq-answer">
                        <div class="stravon-faq-answer-content">
                            Absolutely! We specialize in M-Pesa integration and have successfully implemented it for numerous e-commerce clients.
                        </div>
                    </div>
                </div>

                <div class="stravon-faq-item stravon-slide-in">
                    <div class="stravon-faq-question">
                        <span>Do you work with clients outside Kenya?</span>
                        <div class="stravon-faq-toggle"></div>
                    </div>
                    <div class="stravon-faq-answer">
                        <div class="stravon-faq-answer-content">
                            Yes, we serve clients globally. We use modern communication tools to ensure seamless collaboration regardless of location.
                        </div>
                    </div>
                </div>

                <div class="stravon-faq-item stravon-slide-in">
                    <div class="stravon-faq-question">
                        <span>What's included in the hosting service?</span>
                        <div class="stravon-faq-toggle"></div>
                    </div>
                    <div class="stravon-faq-answer">
                        <div class="stravon-faq-answer-content">
                            Our hosting includes reliable servers, security monitoring, regular backups, SSL certificates, and technical support.
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section class="stravon-contact-section stravon-slide-in">
            <div class="stravon-section-header">
                <h2 class="stravon-section-title">Get in Touch</h2>
                <p class="stravon-section-subtitle">Ready to bring your vision to life? Let's discuss your project</p>
            </div>
            
            <div class="stravon-contact-grid">
                <!-- Contact Form -->
                <div class="stravon-contact-form">
                    <form id="contactForm">
                        <div class="stravon-form-grid">
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="fullName">Full Name *</label>
                                <input type="text" id="fullName" name="fullName" class="stravon-form-input" required>
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="email">Email Address *</label>
                                <input type="email" id="email" name="email" class="stravon-form-input" required>
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="phone">Phone Number *</label>
                                <input type="tel" id="phone" name="phone" class="stravon-form-input" required>
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="company">Company/Organization</label>
                                <input type="text" id="company" name="company" class="stravon-form-input">
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="projectType">Project Type *</label>
                                <select id="projectType" name="projectType" class="stravon-form-select" required>
                                    <option value="">Select Project Type</option>
                                    <option value="web-development">Web Development</option>
                                    <option value="graphic-design">Graphic Design</option>
                                    <option value="both">Both</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="budget">Budget Range *</label>
                                <select id="budget" name="budget" class="stravon-form-select" required>
                                    <option value="">Select Budget Range</option>
                                    <option value="under-20000">Under KES 20,000</option>
                                    <option value="20000-50000">KES 20,000-50,000</option>
                                    <option value="50000-100000">KES 50,000-100,000</option>
                                    <option value="100000-200000">KES 100,000-200,000</option>
                                    <option value="above-200000">Above KES 200,000</option>
                                </select>
                            </div>
                        </div>

                        <div class="stravon-form-group">
                            <label class="stravon-form-label" for="timeline">Project Timeline *</label>
                            <select id="timeline" name="timeline" class="stravon-form-select" required>
                                <option value="">Select Timeline</option>
                                <option value="asap">ASAP</option>
                                <option value="1-2-weeks">1-2 weeks</option>
                                <option value="1-month">1 month</option>
                                <option value="2-3-months">2-3 months</option>
                                <option value="flexible">Flexible</option>
                            </select>
                        </div>

                        <div class="stravon-form-group">
                            <label class="stravon-form-label" for="description">Project Description *</label>
                            <textarea id="description" name="description" class="stravon-form-textarea" required placeholder="Describe your project goals, requirements, and vision..."></textarea>
                        </div>

                        <div class="stravon-form-grid">
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="source">How did you hear about us?</label>
                                <select id="source" name="source" class="stravon-form-select">
                                    <option value="">Select source</option>
                                    <option value="google">Google Search</option>
                                    <option value="social-media">Social Media</option>
                                    <option value="referral">Referral</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="stravon-form-group">
                                <label class="stravon-form-label" for="additional">Additional Requirements</label>
                                <textarea id="additional" name="additional" class="stravon-form-textarea" placeholder="Any specific requirements?"></textarea>
                            </div>
                        </div>

                        <button type="submit" class="stravon-submit-btn">Send Project Inquiry</button>
                    </form>
                    
                    <div id="successMessage" class="stravon-success-message">
                        ✓ Thank you for reaching out! We'll review your project details and get back to you within 24 hours with a detailed proposal.
                    </div>
                    
                    <div id="errorMessage" class="stravon-error-message">
                        ✗ Something went wrong. Please try again or contact us directly.
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="stravon-contact-info">
                    <div class="stravon-info-card">
                        <h3 class="stravon-info-title">
                            <span class="stravon-info-icon">@</span>
                            Primary Contact
                        </h3>
                        <div class="stravon-info-item"><strong>Email:</strong> info@stravontechlabs.com</div>
                        <div class="stravon-info-item"><strong>Phone:</strong> +254 718852518</div>
                        <div class="stravon-info-item"><strong>WhatsApp:</strong> +254 105140326</div>
                    </div>

                    <div class="stravon-info-card">
                        <h3 class="stravon-info-title">
                            <span class="stravon-info-icon">📍</span>
                            Office Location
                        </h3>
                        <div class="stravon-info-item">Kangare, Murang'a County, Kenya</div>
                    </div>

                    <div class="stravon-info-card">
                        <h3 class="stravon-info-title">
                            <span class="stravon-info-icon">🕐</span>
                            Business Hours
                        </h3>
                        <div class="stravon-info-item"><strong>Monday - Friday:</strong> 8:00 AM - 6:00 PM</div>
                        <div class="stravon-info-item"><strong>Saturday:</strong> 9:00 AM - 4:00 PM</div>
                        <div class="stravon-info-item"><strong>Sunday:</strong> Available for urgent support</div>
                    </div>

                    <div class="stravon-info-card">
                        <h3 class="stravon-info-title">
                            <span class="stravon-info-icon">⚡</span>
                            Response Time
                        </h3>
                        <div class="stravon-info-item"><strong>Email inquiries:</strong> Within 24 hours</div>
                        <div class="stravon-info-item"><strong>Phone calls:</strong> Immediate during business hours</div>
                        <div class="stravon-info-item"><strong>Emergency support:</strong> Available 24/7 for maintenance clients</div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>