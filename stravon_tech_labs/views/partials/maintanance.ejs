<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services Toggle</title>
</head>
<body>
    <div class="st-services-container">
        <div class="st-tab-navigation">
            <button class="st-tab-btn st-active" onclick="showTab('st-specialized-services')" data-tab="specialized">
                <span class="st-tab-icon">⚡</span>
                <span class="st-tab-text">Specialized Services</span>
            </button>
            <button class="st-tab-btn" onclick="showTab('st-maintenance-plans')" data-tab="maintenance">
                <span class="st-tab-icon">🛠️</span>
                <span class="st-tab-text">Maintenance Plans</span>
            </button>
        </div>

        <div class="st-content-wrapper">
            <div id="st-specialized-services" class="st-content-section st-active">
                <div class="st-section-header">
                    <h2>Specialized Services</h2>
                    <p>Professional solutions tailored to your business needs</p>
                </div>

                <div class="st-services-grid">
                    <div class="st-service-card" data-animate="st-fade-up">
                        <div class="st-service-header">
                            <h3>M-Pesa Integration</h3>
                            <div class="st-price">KES 25,000</div>
                        </div>
                        <ul class="st-service-features">
                            <li>Secure payment processing</li>
                            <li>Transaction reporting</li>
                            <li>Automated receipt generation</li>
                            <li>Testing and deployment</li>
                        </ul>
                    </div>

                    <div class="st-service-card" data-animate="st-fade-up">
                        <div class="st-service-header">
                            <h3>SEO Management</h3>
                            <div class="st-price">KES 15,000/month</div>
                        </div>
                        <ul class="st-service-features">
                            <li>Keyword research and optimization</li>
                            <li>Content strategy development</li>
                            <li>Technical SEO implementation</li>
                            <li>Monthly performance reports</li>
                        </ul>
                    </div>

                    <div class="st-service-card" data-animate="st-fade-up">
                        <div class="st-service-header">
                            <h3>Social Media Management</h3>
                            <div class="st-price">KES 20,000/month</div>
                        </div>
                        <ul class="st-service-features">
                            <li>Content calendar creation</li>
                            <li>Daily posting across platforms</li>
                            <li>Community engagement</li>
                            <li>Analytics and reporting</li>
                        </ul>
                    </div>

                    <div class="st-service-card" data-animate="st-fade-up">
                        <div class="st-service-header">
                            <h3>Custom API Integration</h3>
                            <div class="st-price">KES 40,000-60,000</div>
                        </div>
                        <ul class="st-service-features">
                            <li>Third-party system connections</li>
                            <li>Data synchronization</li>
                            <li>Testing and documentation</li>
                            <li>Ongoing support</li>
                        </ul>
                    </div>

                    <div class="st-service-card" data-animate="st-fade-up">
                        <div class="st-service-header">
                            <h3>Training Sessions</h3>
                            <div class="st-price">KES 7,000 per session</div>
                        </div>
                        <ul class="st-service-features">
                            <li>2-hour personalized training</li>
                            <li>Custom materials provided</li>
                            <li>30 days of email support</li>
                            <li>Website management guidance</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div id="st-maintenance-plans" class="st-content-section">
                <div class="st-section-header">
                    <h2>Maintenance Plans</h2>
                    <p>Comprehensive support packages to keep your website running smoothly</p>
                </div>

                <div class="st-maintenance-grid">
                    <div class="st-maintenance-card st-basic" data-animate="st-slide-up">
                        <div class="st-plan-badge">Basic</div>
                        <div class="st-plan-header">
                            <h3>Basic Maintenance</h3>
                            <div class="st-price">KES 4,000/month</div>
                        </div>
                        <ul class="st-plan-features">
                            <li>Up to 5 pages</li>
                            <li>Security updates</li>
                            <li>Weekly backups</li>
                            <li>Email support</li>
                            <li>1 hour monthly updates</li>
                        </ul>
                    </div>

                    <div class="st-maintenance-card st-standard" data-animate="st-slide-up">
                        <div class="st-plan-badge">Standard</div>
                        <div class="st-plan-header">
                            <h3>Standard Maintenance</h3>
                            <div class="st-price">KES 6,000/month</div>
                        </div>
                        <ul class="st-plan-features">
                            <li>6-10 pages</li>
                            <li>Daily backups</li>
                            <li>Priority support</li>
                            <li>3 hours of monthly updates</li>
                            <li>Performance reports</li>
                        </ul>
                    </div>

                    <div class="st-maintenance-card st-premium" data-animate="st-slide-up">
                        <div class="st-plan-badge">Premium</div>
                        <div class="st-plan-header">
                            <h3>Premium Maintenance</h3>
                            <div class="st-price">KES 9,000/month</div>
                        </div>
                        <ul class="st-plan-features">
                            <li>11-20 pages</li>
                            <li>24/7 monitoring</li>
                            <li>Emergency support</li>
                            <li>5 hours of monthly updates</li>
                            <li>SEO optimization</li>
                        </ul>
                    </div>

                    <div class="st-maintenance-card st-ecommerce" data-animate="st-slide-up">
                        <div class="st-plan-badge">E-commerce</div>
                        <div class="st-plan-header">
                            <h3>E-commerce Maintenance</h3>
                            <div class="st-price">KES 20,000/month</div>
                        </div>
                        <ul class="st-plan-features">
                            <li>Any size online store</li>
                            <li>Product management</li>
                            <li>Payment monitoring</li>
                            <li>10 hours of monthly updates</li>
                            <li>Sales analysis</li>
                            <li>Conversion optimization</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showTab(sectionId) {
            // Remove active class from all tabs and sections
            document.querySelectorAll('.st-tab-btn').forEach(btn => btn.classList.remove('st-active'));
            document.querySelectorAll('.st-content-section').forEach(section => {
                section.classList.remove('st-active');
            });
            
            // Add active class to clicked tab
            event.target.closest('.st-tab-btn').classList.add('st-active');
            
            // Show selected section with staggered animation
            const section = document.getElementById(sectionId);
            setTimeout(() => {
                section.classList.add('st-active');
                animateCards(section);
            }, 100);
        }

        function animateCards(section) {
            const cards = section.querySelectorAll('[data-animate]');
            cards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.classList.add('st-animate-in');
            });
        }

        // Initialize animations on page load
        document.addEventListener('DOMContentLoaded', function() {
            const activeSection = document.querySelector('.st-content-section.st-active');
            if (activeSection) {
                animateCards(activeSection);
            }
        });
    </script>
</body>
</html>